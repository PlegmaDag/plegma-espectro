# .env.example — PLEGMA DAG
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# ── Node Identity ────────────────────────────────────────────────────────────
NODE_ID=your_node_id_here

# ── Cluster Peers (other nodes to sync with) ─────────────────────────────────
# Point to the official mainnet nodes, or your own cluster.
NODE_URL_EUR=http://213.199.42.88:8080
NODE_URL_USA=http://209.126.7.120:8080
NODE_URL_MUM=http://217.217.251.206:8080
NODE_URL_SIN=http://82.197.70.189:8080

# ── Notifications (optional) ──────────────────────────────────────────────────
# Discord webhook for build/alert notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ALERT_ID/YOUR_ALERT_TOKEN
