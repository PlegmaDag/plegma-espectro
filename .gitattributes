# PLEGMA DAG — Git Attributes
# Normalise line endings: LF in repo, native on checkout

* text=auto

*.py    text eol=lf
*.js    text eol=lf
*.dart  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.ps1   text eol=crlf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.gif   binary
*.db    binary
*.apk   binary
